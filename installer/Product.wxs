<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">
  <Package Name="OTGuru Agent"
           Manufacturer="OTGuru"
           Version="1.0.0"
           UpgradeCode="4A8B3C2D-1E5F-4A8B-9C2D-3E5F6A8B3C2D"
           Scope="perMachine">

    <MajorUpgrade DowngradeErrorMessage="A newer version of OTGuru Agent is already installed." />
    <MediaTemplate EmbedCab="yes" CompressionLevel="high" />

    <ui:WixUI Id="WixUI_OTGuru" />

    <Property Id="TOKEN" Value="" Secure="yes" />

    <!-- Install directory: C:\Program Files\OTGuruAgent\ -->
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="OTGuruAgent" />
    </StandardDirectory>

    <!-- Start Menu shortcut -->
    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="AppMenuFolder" Name="OTGuru Agent" />
    </StandardDirectory>

    <Feature Id="Main" Title="OTGuru Agent" Level="1">
      <ComponentGroupRef Id="ActivityWatchFiles" />
      <ComponentRef Id="StartMenuShortcut" />
    </Feature>

    <!-- ActivityWatchFiles ComponentGroup is generated by CI (installer/HarvestedFiles.wxs) -->

    <!-- Start Menu shortcut + autostart component -->
    <Component Id="StartMenuShortcut" Directory="AppMenuFolder"
               Guid="5B9C4D3E-2F6A-5B9C-AD3E-4F6A7B9C4D3E">
      <Shortcut Id="AppShortcut"
                Name="OTGuru Agent"
                Target="[INSTALLFOLDER]aw-qt.exe"
                WorkingDirectory="INSTALLFOLDER" />
      <RemoveFolder Id="RemoveAppMenuFolder" Directory="AppMenuFolder" On="uninstall" />
      <RegistryValue Root="HKLM"
                     Key="Software\OTGuru\Agent"
                     Name="Installed"
                     Type="integer"
                     Value="1"
                     KeyPath="yes" />
      <!-- Autostart -->
      <RegistryValue Root="HKCU"
                     Key="Software\Microsoft\Windows\CurrentVersion\Run"
                     Name="OTGuruAgent"
                     Value="[INSTALLFOLDER]aw-qt.exe"
                     Type="string" />
    </Component>

    <!-- Post-install: collect PC params, HWID, token, send report -->
    <SetProperty Id="RunPostInstallArgs"
                 Value="&quot;[INSTALLFOLDER]post-install.ps1&quot; -Token &quot;[TOKEN]&quot;"
                 Sequence="execute"
                 Before="RunPostInstall" />

    <CustomAction Id="RunPostInstall"
                  Directory="INSTALLFOLDER"
                  ExeCommand="powershell.exe -ExecutionPolicy Bypass -NonInteractive -File [RunPostInstallArgs]"
                  Execute="deferred"
                  Return="ignore"
                  Impersonate="no" />

    <InstallExecuteSequence>
      <Custom Action="RunPostInstall" After="InstallFiles">NOT Installed</Custom>
    </InstallExecuteSequence>

  </Package>
</Wix>
