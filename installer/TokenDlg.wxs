<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Fragment>
    <UI Id="WixUI_OTGuru">
      <TextStyle Id="WixUI_Font_Normal" FaceName="Tahoma" Size="8" />
      <TextStyle Id="WixUI_Font_Bigger" FaceName="Tahoma" Size="12" />
      <TextStyle Id="WixUI_Font_Title"  FaceName="Tahoma" Size="9" Bold="yes" />

      <Property Id="DefaultUIFont" Value="WixUI_Font_Normal" />

      <DialogRef Id="ErrorDlg" />
      <DialogRef Id="FatalError" />
      <DialogRef Id="FilesInUse" />
      <DialogRef Id="MsiRMFilesInUse" />
      <DialogRef Id="PrepareDlg" />
      <DialogRef Id="ProgressDlg" />
      <DialogRef Id="ResumeDlg" />
      <DialogRef Id="UserExit" />
      <DialogRef Id="WelcomeDlg" />
      <DialogRef Id="InstallDirDlg" />
      <DialogRef Id="VerifyReadyDlg" />

      <!-- WelcomeDlg → TokenDlg -->
      <Publish Dialog="WelcomeDlg" Control="Next" Event="NewDialog" Value="TokenDlg" Order="2">1</Publish>

      <!-- TokenDlg → InstallDirDlg (Next) or InstallDirDlg (skip) -->
      <Publish Dialog="TokenDlg" Control="Next"   Event="NewDialog" Value="InstallDirDlg">1</Publish>
      <Publish Dialog="TokenDlg" Control="Skip"   Property="TOKEN"  Value="">1</Publish>
      <Publish Dialog="TokenDlg" Control="Skip"   Event="NewDialog" Value="InstallDirDlg">2</Publish>
      <Publish Dialog="TokenDlg" Control="Back"   Event="NewDialog" Value="WelcomeDlg">1</Publish>
      <Publish Dialog="TokenDlg" Control="Cancel" Event="SpawnDialog" Value="CancelDlg">1</Publish>

      <!-- InstallDirDlg → VerifyReadyDlg -->
      <Publish Dialog="InstallDirDlg" Control="Next" Event="NewDialog"     Value="VerifyReadyDlg">1</Publish>
      <Publish Dialog="InstallDirDlg" Control="Back" Event="NewDialog"     Value="TokenDlg">1</Publish>

      <!-- VerifyReadyDlg -->
      <Publish Dialog="VerifyReadyDlg" Control="Back" Event="NewDialog"    Value="InstallDirDlg" Order="2">NOT Installed</Publish>
      <Publish Dialog="VerifyReadyDlg" Control="Install" Event="EndDialog" Value="Return">1</Publish>
    </UI>

    <Dialog Id="TokenDlg" Width="370" Height="270" Title="OTGuru Agent — Токен активации">
      <Control Id="Title" Type="Text" X="15" Y="15" Width="340" Height="20"
               Transparent="yes" NoPrefix="yes">
        <Text>{\WixUI_Font_Title}Токен активации</Text>
      </Control>
      <Control Id="Description" Type="Text" X="25" Y="40" Width="320" Height="30" NoPrefix="yes">
        <Text>Введите токен активации, если он у вас есть. Вы также можете пропустить этот шаг.</Text>
      </Control>
      <Control Id="BannerBitmap" Type="Bitmap" X="0" Y="0" Width="370" Height="44"
               TabSkip="yes" Text="WixUI_Bmp_Banner" />
      <Control Id="BannerLine" Type="Line" X="0" Y="44" Width="370" Height="0" />
      <Control Id="BottomLine" Type="Line" X="0" Y="234" Width="370" Height="0" />

      <Control Id="TokenLabel" Type="Text" X="25" Y="90" Width="100" Height="15" NoPrefix="yes">
        <Text>Токен:</Text>
      </Control>
      <Control Id="TokenEdit" Type="Edit" X="25" Y="105" Width="320" Height="20"
               Property="TOKEN" Text="{200}" />

      <Control Id="Back"   Type="PushButton" X="156" Y="243" Width="56" Height="17" Text="&amp;Назад" />
      <Control Id="Next"   Type="PushButton" X="214" Y="243" Width="56" Height="17" Default="yes" Text="&amp;Далее" />
      <Control Id="Skip"   Type="PushButton" X="25"  Y="243" Width="120" Height="17" Text="У меня нет токена" />
      <Control Id="Cancel" Type="PushButton" X="304" Y="243" Width="56" Height="17" Cancel="yes" Text="Отмена" />
    </Dialog>
  </Fragment>
</Wix>
